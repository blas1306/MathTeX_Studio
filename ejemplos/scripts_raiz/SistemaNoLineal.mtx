\clear all;
\clean;

from NewtonMultiVariable import NewtonMultiVariable

f1(x, y, z) = x + y + z + 5;
f2(x, y, z) = x*y + y*z + x*z - 8;
f3(x, y, z) = x*y*z - 444;
F = [f1; f2; f3];
vars = [x, y, z];
x0 = [i; 2; -1];
tol = 1e-8;
maxiter = 100;

[x, res, iter] = NewtonMultiVariable(F, vars, x0, tol, maxiter)
