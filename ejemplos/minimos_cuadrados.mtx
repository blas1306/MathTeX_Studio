t = [-1; 0; 1; 2];
f(t) = t.^5 + 2*t.^3 + 5*t.^2 + 10*t - 75;
[m] = \size(t);
A = [\ones(m,1), t, t.^5];
b = \zeros(m,1);

for i = 1:m
    b(i) = f(t(i));
end

x = A | b;

g(t) = x(1) + x(2)*t + x(3)*t.^5;

\plot(t, b, "o");
\hold(on);
\plot(f, g, \min(t)-1, \max(t)+1);
\grid(on);

\legend("Datos (t, f(t))", "f(t)", "Ajuste: x1 + x2*t + x3*t^5", "location", "northwest");
\xlabel("t");
\ylabel("y");
\title("Least Squares: fit x1 + x2*t + x3*t^5");
