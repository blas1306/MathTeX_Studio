f(t) = t.^5 + 15*t - 44;
t = [-1; 0; 2];
y = f(t);

[m] = \size(t);
A = [\ones(m,1), t.^5];

x = A | y

r = y - A*x;
er = \norm(r);
err2 = er^2

g(t) = x(1) + x(2)*t.^5;

\grid(on);
\hold(on);
\xlabel("t");
\ylabel("y");
\title("Least Squares: fit x1 + x2 t^5");
\plot(t, y, "o");
\plot(f, g, -2, 2);
\legend("Datos", "f(t)", "Ajuste", "location", "northwest")
